# Stripe (optional — app works in demo mode without these)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret (get from Stripe Dashboard → Webhooks)
# Required for reliable payment confirmation via webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# App base URL (used for Stripe redirects and sitemap)
NEXT_PUBLIC_BASE_URL=https://your-app.replit.app
